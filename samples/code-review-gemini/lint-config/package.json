{
  "name": "code-review-gemini-lint",
  "private": true,
  "description": "Lint dependencies for the code-review-gemini sample. Run `npm install` in this folder if you want lint-check.sh to find local binaries.",
  "scripts": {
    "lint": "eslint --config .eslintrc.json --no-eslintrc '../examples/**/*.{ts,tsx}'",
    "format:check": "prettier --config .prettierrc --check '../examples/**/*.{ts,tsx}'",
    "typecheck": "tsc --project tsconfig.review.json --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
