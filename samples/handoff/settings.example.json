{
  "_comment": "Claude Code 의 ~/.claude/settings.json 에서 handoff 시스템(커스텀 Python 훅) 을 등록하는 예시. 기존 hooks 블록과 병합하세요. 플러그인 claude-handoff 와 함께 쓰면 PreCompact 가 중복 발화하니 참고.",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre-compact-handoff.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/session-end-handoff.py",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-restore.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-restore.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
