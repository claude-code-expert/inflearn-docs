{
  // ┌─────────────────────────────────────────────────────────────┐
  // │                  Claude Code settings.json                  │
  // │                                                             │
  // │  이 파일은 JSONC(JSON with Comments) 형식입니다.                 │
  // │  표준 JSON 파서가 아닌 Claude Code 전용 파서로 읽힙니다.             │
  // └─────────────────────────────────────────────────────────────┘

  // ═══════════════════════════════════════════════════════════════
  // 훅(Hooks) 작성 규칙 - 주석은 제거 하고 사용
  // ═══════════════════════════════════════════════════════════════
  //
  // [1] matcher — 반드시 PascalCase 도구 이름을 사용할 것
  //     ✅ "Bash"       ❌ "bash"
  //     ✅ "Write|Edit" ❌ "write_file|edit_file|multiedit_file"
  //     사용 가능한 도구: Bash, Read, Write, Edit, Glob, Grep, ...
  //
  // [2] 입력 읽기 — 훅은 stdin으로 JSON을 수신함. 환경변수 사용 불가.
  //     Claude Code가 stdin으로 전달하는 JSON 구조:
  //     {
  //       "tool_name": "Bash",
  //       "tool_input": { "command": "..." }          // Bash 훅
  //       "tool_input": { "file_path": "..." }        // Write/Edit 훅
  //       "tool_response": { "filePath": "..." }      // PostToolUse 전용
  //     }
  //
  //     ✅ cmd=$(jq -r '.tool_input.command // ""')
  //     ✅ f=$(jq -r '.tool_input.file_path // ""')
  //     ❌ echo "$CLAUDE_TOOL_INPUT"   ← 이 변수는 존재하지 않음
  //     ❌ "$CLAUDE_FILE_PATH"         ← 이 변수는 존재하지 않음
  //
  // [3] 차단 방법 — PreToolUse에서 exit 2로 도구 실행을 중단시킴
  //     ✅ ... && exit 2 || exit 0
  //     PostToolUse/Stop은 차단 불가 (이미 실행 완료 후)
  //
  // [4] git commit 패턴 — 체인 명령(&&, ;, ||) 우회를 막으려면:
  //     ✅ grep -E '(^|\|\||&&|;)\s*git\s+(commit|push)'
  //     ❌ grep -E '^git\s+(commit|push)'  ← "git add && git commit" 우회됨
  //
  // [5] 이벤트 종류
  //     PreToolUse  : 도구 실행 전 (차단 가능, exit 2)
  //     PostToolUse : 도구 실행 후 (차단 불가, 후처리용)
  //     Stop        : 응답 완료 후 (전체 검증용)
  //     matcher ""  : Stop 이벤트에서 항상 실행

  // settings.json 스키마. IDE 자동완성·오타 검증을 켠다.
  // 값이 비었거나 잘못되면 파일 전체가 무시되므로 정확한 URL만 사용한다.

  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  // ═══════════════════════════════════════════════════════════════
  // permissions — 도구 허용/차단 (훅과 별도 시스템)
  // ═══════════════════════════════════════════════════════════════
  //
  // 형식: "Tool(pattern*)"  (* = 접두사 와일드카드)
  // deny는 allow보다 우선 적용됨
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run format)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run db:generate)",
      "Bash(npm run db:studio)"
    ],
    "deny": [
      // 파괴적 git — 단어경계(공백+*)로 명령 계열 차단
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git commit --no-verify *)",
      "Bash(npm audit fix --force *)",

      // 파괴적 파일 명령
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",

      // 비밀 파일 — 빌트인 도구 차단 (gitignore 문법)
      "Read(./.env*)",
      "Edit(./.env*)",
      "Write(./.env*)",
      // ⚠️ Bash 우회(cat/less 등)는 위 규칙으로 못 막음 → 아래 추가 필수
      "Bash(cat .env*)",
      "Bash(less .env*)",
      "Bash(head .env*)",

      // 마이그레이션 보호 — ** 로 재귀(하위 폴더까지)
      "Edit(migrations/**)",
      "Write(migrations/**)"
    ]
  },

  // ════════════════════════════════════════════════════════════
  // hooks — 특정 시점에 셸 명령 자동 실행
  //   · 페이로드는 stdin JSON으로 전달 → jq로 파싱 (환경변수 아님)
  //   · PreToolUse에서 exit 2 = 차단 + stderr가 모델에 전달되어 재시도 유도
  //   · exit 1 은 비차단 경고 (작업 그대로 진행) — 차단 아님
  // ════════════════════════════════════════════════════════════
  "hooks": {
    // ── 도구 실행 "전" 검증/차단 ──
    "PreToolUse": [
      {
        "matcher": "Bash",   // Bash 도구 호출에만 발동
        "hooks": [
          {
            // SQL 파괴 명령(DROP/TRUNCATE) 차단.
            // permissions deny보다 견고: 명령 "내용 기반" + 모델에 사유 피드백.
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -iE '(DROP\\s+TABLE|DROP\\s+DATABASE|TRUNCATE)' >/dev/null 2>&1 && echo '❌ DROP/TRUNCATE 명령은 금지되어 있습니다.' >&2 && exit 2 || exit 0"
          },
          {
            // WHERE 절 없는 DELETE FROM 차단 (휴리스틱).
            // 멀티라인·서브쿼리에서는 오판 가능 → DB 읽기전용 계정과 병행 권장.
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -iE 'DELETE\\s+FROM' >/dev/null 2>&1 && ! echo \"$cmd\" | grep -iE 'WHERE' >/dev/null 2>&1 && echo '❌ DELETE FROM은 WHERE 절 없이 사용 금지입니다.' >&2 && exit 2 || exit 0"
          },
          {
            // 사용자의 명시적 요청 없는 git commit/push 차단.
            // 정규식으로 명령 시작·체인(|| && ;) 뒤의 git commit/push 탐지.
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -E '(^|\\|\\||&&|;)\\s*git\\s+(commit|push)' >/dev/null 2>&1 && echo '❌ git commit/push는 명시적 요청 없이 실행할 수 없습니다.' >&2 && exit 2 || exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit",   // 파일 쓰기·편집 도구에만 발동
        "hooks": [
          {
            // 핵심 설정 파일(schema.ts, drizzle.config.ts, next.config.ts, .env*) 수정 차단.
            // .tool_input.file_path 를 case 패턴으로 검사.
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // \"\"'); case \"$f\" in */schema.ts|*/drizzle.config.ts|*/next.config.ts|*.env|*.env.*) echo \"⚠️ 보호된 파일입니다. 사용자 확인이 필요합니다: $f\" >&2; exit 2;; esac"
          },
          {
            // 수정 "전" 원본을 .bak 으로 자동 백업.
            // || true 로 실패해도 작업 흐름이 끊기지 않게 한다.
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // \"\"'); [ -n \"$f\" ] && [ -f \"$f\" ] && cp \"$f\" \"$f.bak\" 2>/dev/null || true"
          }
        ]
      }
    ],

    // ── 도구 실행 "후" 보정 (이미 실행됨 → 차단 불가, 자동 수정용) ──
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            // 수정된 파일에 ESLint 자동 수정 적용.
            // 매 파일 수정마다 도므로 가볍게 유지. 결과 경로 우선, 없으면 입력 경로.
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path // \"\"'); [ -n \"$f\" ] && npx eslint --fix \"$f\" 2>/dev/null || true"
          }
        ]
      }
    ],

    // ── Claude 응답 완료 시 (무거운 전체 검증은 여기에 배치) ──
    "Stop": [
      {
        "matcher": "",   // 빈 문자열 = 모든 경우 발동
        "hooks": [
          {
            // 전체 타입 체크. tail -30 으로 출력량 제한 → 컨텍스트 낭비 방지.
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -30"
          }
        ]
      }
    ]
  }
}